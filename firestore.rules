
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isParent(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'parent';
    }

    function isCaregiver(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role == 'caregiver';
    }

    function isLinked(parentId) {
      return exists(/databases/$(database)/documents/relationships/$(parentId + "_" + request.auth.uid));
    }

    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // Relationships - Pairing & Relationships System
    // Users can only read relationships they are part of
    // No direct creates (must use Cloud Function)
    // Users can delete relationships they are part of
    match /relationships/{relId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == resource.data.parentUid || 
         request.auth.uid == resource.data.caregiverUid);
      allow create: if false;
      allow delete: if isSignedIn() && 
        (request.auth.uid == resource.data.parentUid || 
         request.auth.uid == resource.data.caregiverUid);
      allow update: if false;
    }

    match /medicines/{medicineId} {
      allow read: if request.auth.uid == resource.data.parentId || isLinked(resource.data.parentId);
      allow create: if isCaregiver(request.auth.uid);
      allow update: if isCaregiver(request.auth.uid);
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow write: if isCaregiver(request.auth.uid);
    }

    match /doses/{doseId} {
      allow read: if request.auth.uid == resource.data.parentId || isLinked(resource.data.parentId);
      allow update: if request.auth.uid == resource.data.parentId;
      allow create: if isSignedIn();
    }

    // Invite Codes - Pairing & Relationships System
    // Parents can only read their own codes
    // Parents can create codes for themselves
    // No direct updates or deletes (handled by Cloud Functions)
    match /inviteCodes/{code} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.parentUid;
      allow create: if isSignedIn() && 
        request.auth.uid == request.resource.data.parentUid &&
        request.resource.data.keys().hasAll(['code', 'parentUid', 'createdAt', 'expiresAt']) &&
        request.resource.data.code is string &&
        request.resource.data.code.size() == 8;
      allow update, delete: if false;
    }

    match /deviceTokens/{tokenId} {
      allow write: if isSignedIn();
      allow read: if false;
    }
  }
}
